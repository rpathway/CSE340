<h1>Add New Inventory Item</h1>
<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
<div class="form-container">
  <form action="/inv/add-inventory" method="post" id="addInvForm">
    <label for="classification_id">Classification<span class="required">*</span></label>
    <%- classificationList %>

    <label for="inv_make">Make<span class="required">*</span></label>
    <input type="text" id="inv_make" name="inv_make" value="<%= locals.inv_make %>" minlength="1" required>
    <label for="inv_model">Model<span class="required">*</span></label>
    <input type="text" id="inv_model" name="inv_model" value="<%= locals.inv_model %>" minlength="1" required>
    <label for="inv_year">Year<span class="required">*</span></label>
    <input type="number" id="inv_year" name="inv_year" value="<%= locals.inv_year %>" min="1900" max="2099" minlength="4" maxlength="4" required>
    <label for="inv_description">Description<span class="required">*</span></label>
    <textarea id="inv_description" name="inv_description" rows="4" required><%= locals.inv_description %></textarea>
    <label for="inv_image">Image Path<span class="required">*</span></label>
    <input type="text" id="inv_image" name="inv_image" value="<%= locals.inv_image || '/images/vehicles/no-image.png' %>" required>
    <label for="inv_thumbnail">Thumbnail Path<span class="required">*</span></label>
    <input type="text" id="inv_thumbnail" name="inv_thumbnail" value="<%= locals.inv_thumbnail || '/images/vehicles/no-image-tn.png' %>" required>
    <label for="inv_price">Price<span class="required">*</span></label>
    <input type="number" id="inv_price" name="inv_price" value="<%= locals.inv_price %>" min="0" step="0.01" required>
    <label for="inv_miles">Miles<span class="required">*</span></label>
    <input type="number" id="inv_miles" name="inv_miles" value="<%= locals.inv_miles %>" min="0" required>
    <label for="inv_color">Color<span class="required">*</span></label>
    <input type="text" id="inv_color" name="inv_color" value="<%= locals.inv_color %>" required>

    <input type="submit" value="Add Vehicle">
  </form>
</div>