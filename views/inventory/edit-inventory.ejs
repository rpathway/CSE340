<h1>Edit Inventory Item</h1>
<%- messages() %>
<% if (errors) { %>
  <ul class="notice">
    <% errors.array().forEach(error => { %>
      <li><%= error.msg %></li>
    <% }) %>
  </ul>
<% } %>
<div class="form-container">
  <form action="/inv/update" method="post" id="updateForm">
    <label for="classification_id">Classification<span class="required">*</span></label>
    <%- classificationSelect %>

    <label for="inv_make">Make<span class="required">*</span></label>
    <input type="text" id="inv_make" name="inv_make" value="<%- inv_make %>" minlength="1" required>
    <label for="inv_model">Model<span class="required">*</span></label>
    <input type="text" id="inv_model" name="inv_model" value="<%- inv_model %>" minlength="1" required>
    <label for="inv_year">Year<span class="required">*</span></label>
    <input type="number" id="inv_year" name="inv_year" value="<%- inv_year %>" min="1900" max="2099" minlength="4" maxlength="4" required>
    <label for="inv_description">Description<span class="required">*</span></label>
    <textarea id="inv_description" name="inv_description" rows="4" required><%- inv_description %></textarea>
    <label for="inv_image">Image Path<span class="required">*</span></label>
    <input type="text" id="inv_image" name="inv_image" value="<%- inv_image || '/images/vehicles/no-image.png' %>" required>
    <label for="inv_thumbnail">Thumbnail Path<span class="required">*</span></label>
    <input type="text" id="inv_thumbnail" name="inv_thumbnail" value="<%- inv_thumbnail || '/images/vehicles/no-image-tn.png' %>" required>
    <label for="inv_price">Price<span class="required">*</span></label>
    <input type="number" id="inv_price" name="inv_price" value="<%- inv_price %>" min="0" step="0.01" required>
    <label for="inv_miles">Miles<span class="required">*</span></label>
    <input type="number" id="inv_miles" name="inv_miles" value="<%- inv_miles %>" min="0" required>
    <label for="inv_color">Color<span class="required">*</span></label>
    <input type="text" id="inv_color" name="inv_color" value="<%- inv_color %>" required>

    <input type="submit" name="submit" value="Update Vehicle" disabled>
    <input type="hidden" name="inv_id" <% if(locals.inv_id) { %> value="<%= locals.inv_id %>" <% } %>>
  </form>
</div>
<script src="/js/inv-update.js"></script>